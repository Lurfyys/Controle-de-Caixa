generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  companyName String?
  createdAt   DateTime @default(now())

  inventory Inventory[]
  cash      CashTransaction[]
  agenda    CalendarEvent[]
  notes     Note[]
  kanban    KanbanTask[]
  settings  Settings?
}

model Inventory {
  id          String   @id @default(uuid())
  userId      String
  name        String
  category    String
  weight      Float?
  goldType    String?
  gem         String?
  costPrice   Float
  sellPrice   Float
  quantity    Int      @default(1)
  status      String   @default("Disponível")
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CashTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String
  category    String
  subcategory String?
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  date        DateTime
  time        String?
  location    String?
  color       String?
  priority    String   @default("media")
  status      String   @default("pendente")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id         String   @id @default(uuid())
  userId     String
  title      String
  content    String?
  color      String?
  imageUrl   String?
  tags       String[]
  isPinned   Boolean  @default(false)
  checklist  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KanbanTask {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  status      String   @default("A Fazer")
  priority    String   @default("media")
  dueDate     DateTime?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id               String   @id @default(uuid())
  userId           String   @unique
  theme            String   @default("luxo")
  companyName      String?
  cnpj             String?
  currency         String   @default("BRL")
  proLaboreGoal    Float?
  categories       String[]
  subcategories    Json?
  dashboardWidgets Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}